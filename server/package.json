{
  "name": "@hrms/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "dev:start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "build": "node --env-file=.env ./build.mjs",
    "start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "pnpm --filter @hrms/db run generate",
    "db:migrate": "pnpm --filter @hrms/db run migrate",
    "db:push": "pnpm --filter @hrms/db run push",
    "db:studio": "pnpm --filter @hrms/db run studio",
    "db:check": "pnpm --filter @hrms/db run check",
    "db:seed": "pnpm --filter @hrms/db run seed"
  },
  "dependencies": {
    "@hrms/api-zod": "workspace:*",
    "@hrms/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
