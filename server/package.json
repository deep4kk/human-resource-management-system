{
  "name": "@hrms/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "dev:start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "build": "node --env-file=.env ./build.mjs",
    "start": "node --env-file=.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:seed": "pnpm --filter @hrms/db run seed"
  },
  "dependencies": {
    "@hrms/api-zod": "workspace:*",
    "@hrms/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "csv-parse": "^7.0.0",
    "csv-stringify": "^6.8.0",
    "express": "^5",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "pino": "^9",
    "pino-http": "^10",
    "streamifier": "^0.1.1",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/uuid": "^11.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
