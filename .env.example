# Flowmative HRMS - Environment Variables
# Copy to the respective subdirectory and configure
# See LOCAL_DEV.md for detailed setup instructions.

# Server (server/.env)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/hrms
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
PORT=5001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Frontend (frontend/.env)
VITE_API_URL=http://localhost:5001
BASE_PATH=/

# ─── Important Notes ───────────────────────────────────────────
# Password hashing: SHA256(password + "hrms_salt_flowmative")
# Both server/src/lib/auth.ts and packages/db/src/seed.ts use
# the same salt. If you change one, update the other, then
# re-seed: cd server && pnpm run db:seed
# ───────────────────────────────────────────────────────────────
